#!/usr/bin/make -f
# Debian packaging rules for NetCtl

include /usr/share/dpkg/default.mk

export DEB_BUILD_OPTIONS=parallel=$(shell nproc)
export CARGO_HOME=$(CURDIR)/debian/.cargo

%:
	dh $@ --buildsystem=cargo

override_dh_auto_build:
	cd backend && cargo build --release --lib --bin netctl-daemon --bin netctl-cli --bin netctl-tui
	cd frontend && npm install && npm run build

override_dh_auto_test:
	cd backend && cargo test --release --lib

override_dh_auto_install:
	# Binary installation
	dh_auto_install
	mkdir -p debian/netctl/usr/bin
	install -m 0755 backend/target/release/netctl-daemon debian/netctl/usr/bin/
	install -m 0755 backend/target/release/netctl-cli debian/netctl/usr/bin/
	install -m 0755 backend/target/release/netctl-tui debian/netctl/usr/bin/
	
	# Dashboard installation (frontend)
	mkdir -p debian/netctl-dashboard/usr/share/netctl/dashboard
	cp -r frontend/dist/* debian/netctl-dashboard/usr/share/netctl/dashboard/
	
	# Systemd service
	mkdir -p debian/netctl/etc/systemd/system
	install -m 0644 backend/systemd/netctl.service debian/netctl/etc/systemd/system/
	
	# Configuration directory
	mkdir -p debian/netctl/etc/netctl
	mkdir -p debian/netctl/var/lib/netctl
	mkdir -p debian/netctl/var/log/netctl
	mkdir -p debian/netctl/var/run/netctl
	
	# Documentation
	mkdir -p debian/netctl/usr/share/doc/netctl
	install -m 0644 README.md debian/netctl/usr/share/doc/netctl/
	install -m 0644 API.md debian/netctl/usr/share/doc/netctl/
	install -m 0644 USAGE.md debian/netctl/usr/share/doc/netctl/

override_dh_installdocs:
	dh_installdocs --all README.md

override_dh_installsystemd:
	dh_installsystemd --name=netctl --no-start

override_dh_strip:
	dh_strip --no-automatic-dbgsym
